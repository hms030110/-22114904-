//1. 데이터 모델
class Schedule implements Serializable {
    private static final long serialVersionUID = 1L;

    String title;
    int dayIdx;
    int start;
    int end;
    Color color;
    String memo;
    Color memoColor;

    public Schedule(String title, int dayIdx, int start, int end, Color color) {
        this.title = title;
        this.dayIdx = dayIdx;
        this.start = start;
        this.end = end;
        this.color = color;
        this.memo = "";
        this.memoColor = Color.BLACK;
    }
}

